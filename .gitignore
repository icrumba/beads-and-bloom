# Secrets
.env
.mcp.json

# User data (created per-install)
context/memory/*
!context/memory/.gitkeep
projects/*
!projects/.gitkeep
brand_context/*.md
!brand_context/.gitkeep

# Installer state
.claude/skills/_catalog/installed.json

# Local settings
.claude/settings.local.json
.claude/hooks_info/ccnotify.db
.claude/hooks_info/ccnotify.log*

# System
.DS_Store
.backup/

# Cron (system jobs are tracked, user-created jobs are not)
cron/jobs/*
!cron/jobs/.gitkeep
!cron/jobs/monthly-learnings-health.md
!cron/jobs/skill-update-check.md
!cron/jobs/weekly-activity-digest.md
cron/logs/
cron/status/

# Client workspaces (all client data is local)
clients/
