# ===========================================
# Beads & Bloom Environment Variables
# Copy this file to .env.local and fill in values
# ===========================================

# --- Database (Neon Postgres) ---
# Get from: https://console.neon.tech > Project > Connection Details
# Free tier: 0.5GB storage, 100 compute-hours/month
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- Stripe ---
# Get from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_ / pk_test_) for development, live keys for production
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get from: https://dashboard.stripe.com/webhooks (after creating endpoint)
# For local dev: run `stripe listen --forward-to localhost:3000/api/webhook` and use the provided secret
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Cloudinary (Product images) ---
# Get from: https://console.cloudinary.com > Dashboard
# Free tier: 25GB storage, 25GB bandwidth/month
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
# Create an unsigned upload preset: Settings > Upload > Upload Presets > Add
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset
# API credentials (used by seed script for image upload)
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Resend (Email notifications) ---
# Get from: https://resend.com/api-keys
# Free tier: 100 emails/day (3,000/month)
RESEND_API_KEY=re_...
# Verified sender email -- must verify domain in Resend dashboard first
RESEND_FROM_EMAIL=orders@yourdomain.com
# Email address to receive admin order notifications
ADMIN_EMAIL=your-email@example.com

# --- Twilio (SMS notifications) ---
# Get from: https://console.twilio.com
# Pay-per-use: ~$0.0079/SMS + $1/month phone number
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890
# ADMIN_PHONE_NUMBER=+1234567890

# --- Admin Auth ---
# Choose a strong password for the admin dashboard (/admin)
ADMIN_PASSWORD=your-admin-password
# Random string for session cookie signing
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_SESSION_SECRET=random-secret-string

# --- Site ---
# Your production URL (no trailing slash)
# Used for meta tags, OG images, and canonical URLs
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
